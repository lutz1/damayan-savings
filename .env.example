# Frontend environment (used by Vite during development)
REACT_APP_API_BASE_URL=http://localhost:5000
VITE_FIREBASE_APP_ID=your-firebase-web-app-id
VITE_FIREBASE_VAPID_KEY=your-firebase-web-push-certificate-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
VITE_GOOGLE_MAPS_MAP_ID=your-google-maps-map-id-here

# Backend environment (set in Render or locally)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# Optional
OPENAI_API_KEY=sk-...
PORT=5000
