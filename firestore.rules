rules_version = '2'; 
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // 🔹 Helper: Get current user's role
    function userRole() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "").lower().matches('^\\s*superadmin\\s*$')
              ? "superadmin"
              : (
                  get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "").lower().matches('^\\s*admin\\s*$')
                    ? "admin"
                    : (
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "").lower().matches('^\\s*ceo\\s*$')
                          ? "ceo"
                          : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "").lower()
                      )
                )
          )
        : "";
    }

    function userEmail() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.lower()
        : "";
    }

    function isAdminOrCEO() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower().matches('^\\s*admin\\s*$') ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower().matches('^\\s*ceo\\s*$') ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower().matches('^\\s*superadmin\\s*$')
        );
    }

    function isMerchant() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower().matches('^\\s*merchant\\s*$');
    }

    function isRider() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower().matches('^\\s*rider\\s*$');
    }

    function merchantCanReceiveOrders(merchantId) {
      return (
        exists(/databases/$(database)/documents/users/$(merchantId)) &&
        get(/databases/$(database)/documents/users/$(merchantId)).data.get("merchantStatus", "PENDING_APPROVAL") == "APPROVED" &&
        get(/databases/$(database)/documents/users/$(merchantId)).data.get("open", false) == true
      ) || (
        exists(/databases/$(database)/documents/merchants/$(merchantId)) &&
        get(/databases/$(database)/documents/merchants/$(merchantId)).data.get("status", "PENDING_APPROVAL") == "APPROVED" &&
        get(/databases/$(database)/documents/merchants/$(merchantId)).data.get("open", false) == true
      );
    }

    // 👤 USERS
    match /users/{userId} {

      // Allow reading user profiles (safe fields only)
      // Any authenticated user can read any user profile
      allow read: if request.auth != null;

      // List users:
      // - Admin/CEO can list for management screens
      // - Others can only run bounded username-prefix search
      allow list: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        (
          request.query.limit <= 10 &&
          request.query.where("username", ">=") &&
          request.query.where("username", "<=")
        )
      );

      // CREATE
      allow create: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];

      // UPDATE - Allow admin SDK (no auth context) OR user updating their own OR admin/ceo (including merchants)
      allow update: if (
        // Admin SDK (server-side)
        request.auth == null ||
        // User updating their own profile or merchant updating their profile
        (
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "eWallet",
            "eWalletBalance",
            "capitalShareActive",
            "capitalActivatedAt",
            "capitalProfitBalance",
            "lastActive",
            "notificationsSeen",
            "profilePicture",
            "onlineStatus",
            "availability",
            "lat",
            "lng",
            "currentLocation",
            "lastLocationUpdate",
            "name",
            "contactNumber",
            "address",
            "username",
            "updatedAt",
            "storeName",
            "storeDescription",
            "ownerName",
            "phone",
            "email",
            "city",
            "open",
            "latitude",
            "longitude",
            "businessPermitUrl",
            "coverImage",
            "logo",
            "storeBannerImage",
            "storeLogo",
            "operationHours",
            "preparationTime",
            "category",
            "capitalShareVoucherType",
             "fcmToken",
             "fcmTokens",
             "pushToken",
             "notificationToken",
             "lastPushTokenUpdate",
            "capitalShareVoucherUpdatedAt",
            "capitalShareVoucherBranchId",
            "capitalShareVoucherBranchName",
            "capitalShareVoucherBranchAddress",
            "capitalShareVoucherBranchEmail",
            "deliveryAddress",
            "deliveryAddressCityProvince",
            "deliveryAddressLocation",
            "deliveryAddressUpdatedAt",
            "favoriteStores"
          ])
        ) ||
        // Admin/CEO
        userRole() in ["admin", "ceo", "superadmin"]
      );
    }

    // ==========================================
    // 🛵 RIDER APPLICATIONS
    match /riderApplications/{applicationId} {
      allow read: if request.auth != null && (
        isAdminOrCEO() ||
        resource.data.memberUid == request.auth.uid ||
        (
          resource.data.memberEmail is string &&
          resource.data.memberEmail.lower() == userEmail()
        )
      );

      allow list: if request.auth != null && isAdminOrCEO();

      allow create: if request.auth != null && (
        isAdminOrCEO() ||
        request.resource.data.memberUid == request.auth.uid ||
        (
          request.resource.data.memberEmail is string &&
          request.resource.data.memberEmail.lower() == userEmail()
        )
      );

      allow update: if request.auth != null && (
        isAdminOrCEO() ||
        resource.data.memberUid == request.auth.uid
      );

      allow delete: if request.auth != null && isAdminOrCEO();
    }

    // ==========================================
    // 🎟️ CAPITAL SHARE VOUCHERS
    match /capitalShareVouchers/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdminOrCEO() || isMerchant());

      allow create, update: if
        request.auth == null ||
        (
          request.auth != null &&
          (
            request.auth.uid == userId ||
            isAdminOrCEO() ||
            (
              // Legacy top-level voucher shape.
              isMerchant() &&
              resource.data.voucherStatus == "ACTIVE" &&
              resource.data.voucherType == "WALK_IN" &&
              (
                (resource.data.branchId is string && resource.data.branchId == request.auth.uid) ||
                (resource.data.branchEmail is string && resource.data.branchEmail.lower() == userEmail())
              ) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "voucherStatus",
                "redeemedAt",
                "redeemedByMerchantId",
                "redeemedByMerchantName",
                "redeemedByMerchantEmail",
                "updatedAt"
              ]) &&
              request.resource.data.voucherStatus == "REDEEMED" &&
              request.resource.data.redeemedByMerchantId == request.auth.uid
            ) ||
            (
              // Current voucher-list shape used by merchant app redemption.
              isMerchant() &&
              resource.data.vouchers is list &&
              request.resource.data.vouchers is list &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "vouchers",
                "lastUpdatedAt",
                "lastRedeemedVoucherCode",
                "lastRedeemedAt",
                "lastRedeemedByMerchantId",
                "lastRedeemedByMerchantEmail",
                "voucherStatus"
              ]) &&
              request.resource.data.lastRedeemedByMerchantId == request.auth.uid
            )
          )
        );

      allow delete: if request.auth != null &&
        (request.auth.uid == userId || isAdminOrCEO());
    }

    // ==========================================
    // 📩 PENDING INVITES
    match /pendingInvites/{inviteId} {
      allow read: if request.auth != null &&
        (userRole() in ["admin", "ceo", "superadmin"] || resource.data.inviterId == request.auth.uid);

      allow create: if request.auth != null &&
        (userRole() in ["admin", "ceo", "superadmin"] || request.resource.data.inviterId == request.auth.uid);

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💸 REFERRAL REWARDS
    match /referralReward/{rewardId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll([
          "userId", "username", "role", "amount",
          "source", "type", "approved",
          "payoutReleased", "createdAt"
        ]);

      allow update: if (
        // Allow server-side (Admin SDK with no auth context) to update transferred status
        request.auth == null ||
        // Allow admin/ceo to update anything
        (request.auth != null && userRole() in ["admin", "ceo", "superadmin"]) ||
        // Allow user to update their own reward's transfer status
        (
          request.auth != null &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "approved",
            "payoutReleased",
            "updatedAt",
            "transferredAmount",  
            "dateTransferred"    
          ])
        )
      );

      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 📋 REFERRAL REWARD TRANSFER LOGS
    match /referralRewardTransferlogs/{logId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow list: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        request.query.where("userId", "==", request.auth.uid)
      );

      // Only server-side (Admin SDK) can create transfer logs
      allow create: if request.auth == null;

      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // � UPLINE REWARDS
    match /uplineRewards/{rewardId} {
      // Allow upline to read their own rewards
      allow read: if request.auth != null &&
        (resource.data.uplineId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      // Allow listing rewards for current upline
      allow list: if request.auth != null &&
        request.query.where("uplineId", "==", request.auth.uid);

      // Only server (Admin SDK) can create upline rewards
      allow create: if request.auth == null;

      // Allow upline to claim/update their rewards
      allow update: if request.auth != null &&
        (
          (resource.data.uplineId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "claimed",
              "claimedAt",
              "transferredAmount",
              "status",
              "updatedAt"
            ])
          ) ||
          userRole() in ["admin", "ceo", "superadmin"]
        );

      // Only admins can delete
      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    match /paybackEntries/{docId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          resource.data.uplineUsername ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
        ) ||
        userRole() in ["admin", "ceo", "superadmin"]
      );

      allow list: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        request.query.where("userId", "==", request.auth.uid)
      );

      allow create: if request.auth != null &&
        (request.resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          resource.data.uplineUsername ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
        ) ||
        userRole() in ["admin", "ceo", "superadmin"]
      );

      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💰 CAPITAL SHARE ENTRIES
    match /capitalShareEntries/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
    }

    // ==========================================
    // 💹 CAPITAL SHARE PROFITS
    match /capitalShareProfits/{docId} {
      allow read, create, update: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);
    }

    // ==========================================
    // 🧾 PURCHASE CODES
    match /purchaseCodes/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdminOrCEO());

      allow list: if request.auth != null && (
        isAdminOrCEO() ||
        request.query.where("userId", "==", request.auth.uid)
      );

      allow create: if request.auth != null &&
        (request.resource.data.userId == request.auth.uid || isAdminOrCEO());

      allow update: if request.auth != null &&
        (
          isAdminOrCEO() ||
          (
            resource.data.userId == request.auth.uid &&
            resource.data.used == false &&
            request.resource.data.used == true
          )
        );

      allow delete: if request.auth != null && isAdminOrCEO();
    }

    // ==========================================
    // 📥 REQUESTS
    match /requests/{docId} {
      allow read, write: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 📊 PAYBACK PROFIT HISTORY
    match /paybackProfitHistory/{docId} {
      allow read, create: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 🔄 PASSIVE TRANSFERS
    match /passiveTransfers/{docId} {
      allow read, create: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);
    }

    // ==========================================
    // 💼 OVERRIDE (upline rewards)
    match /override/{docId} {
      allow read, list: if request.auth != null && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.uplineId == request.auth.uid ||
        userRole() in ["admin", "ceo", "superadmin"]
      );

      allow create: if request.auth != null &&
        (request.resource.data.fromUserId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💼 TRANSFER TRANSACTIONS
    match /transferTransactions/{docId} {
      allow read, write: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💳 WALLETS
    match /wallets/{walletId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💵 DEPOSITS
    match /deposits/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow create: if (
        // Allow Admin SDK (server-side) to create deposit records
        request.auth == null ||
        // Allow users to create their own deposits
        (request.auth != null && request.resource.data.userId == request.auth.uid)
      );

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💵 WITHDRAWALS
    match /withdrawals/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 💸 WALLET-TO-WALLET TRANSFERS
    match /transferFunds/{docId} {
      allow read: if request.auth != null && (
        resource.data.senderId == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          resource.data.recipientUsername ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username
        ) ||
        userRole() in ["admin", "ceo", "superadmin"]
      );

      allow list: if request.auth != null &&
        request.query.where("senderId", "==", request.auth.uid);

      // Allow server-side (Admin SDK with no auth) to create approved transfers
      allow create: if request.auth == null || 
        (
          request.auth != null &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.amount is number &&
          request.resource.data.charge is number &&
          request.resource.data.netAmount is number &&
          request.resource.data.status == "Pending"
        );

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 🛍️ PRODUCTS
    match /products/{productId} {
      allow create: if request.auth != null &&
        request.resource.data.merchantId == request.auth.uid;

      allow read: if resource.data.status == "active" ||
        (request.auth != null && (resource.data.merchantId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]));

      allow update, delete: if request.auth != null &&
        (
          (resource.data.merchantId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "name", "category", "description", "price", "stock", "image", "status", "updatedAt"
            ])
          ) ||
          userRole() in ["admin", "ceo", "superadmin"]
        );
    }

    // 💰 SALES
    match /sales/{saleId} {
      allow read: if request.auth != null &&
        (
          resource.data.merchantId == request.auth.uid ||
          resource.data.customerId == request.auth.uid ||
          userRole() in ["admin", "ceo", "superadmin"]
        );

      allow create: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        (
          request.resource.data.customerId == request.auth.uid &&
          request.resource.data.merchantId is string &&
          merchantCanReceiveOrders(request.resource.data.merchantId) &&
          request.resource.data.status == "PENDING" &&
          request.resource.data.keys().hasAll([
            "merchantId",
            "customerId",
            "customerName",
            "items",
            "subtotal",
            "deliveryFee",
            "total",
            "status",
            "deliveryAddress",
            "createdAt"
          ])
        )
      );

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 🧾 ORDERS (canonical)
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];

      match /items/{itemId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.merchantId == request.auth.uid ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.riderId == request.auth.uid ||
          userRole() in ["admin", "ceo", "superadmin"]
        );

        allow create: if request.auth != null && (
          userRole() in ["admin", "ceo", "superadmin"] ||
          get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid
        );

        allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
      }
    }

    // 📦 ORDER ITEMS (flat analytics copy)
    match /orderItems/{itemId} {
      allow read: if request.auth != null && (
        resource.data.customerId == request.auth.uid ||
        resource.data.merchantId == request.auth.uid ||
        userRole() in ["admin", "ceo", "superadmin"]
      );
      allow create: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        request.resource.data.customerId == request.auth.uid
      );
      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 💬 FEEDBACK
    match /feedback/{feedbackId} {
      allow read: if request.auth != null &&
        (resource.data.merchantId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 🏪 MERCHANTS (store profiles)
    match /merchants/{merchantId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        (request.auth.uid == merchantId || userRole() in ["admin", "ceo", "superadmin"]);
      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 🛵 RIDERS
    match /riders/{riderId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        (request.auth.uid == riderId || userRole() in ["admin", "ceo", "superadmin"]);
      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 🍔 MENUS
    match /menus/{menuId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        (request.resource.data.merchantId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);
      allow delete: if request.auth != null &&
        (resource.data.merchantId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);
    }

    // 💸 EARNINGS (rider earnings)
    match /earnings/{earningId} {
      allow read: if request.auth != null &&
        (resource.data.riderId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);
      allow create, update: if request.auth == null ||
        (request.auth != null && userRole() in ["admin", "ceo", "superadmin"]);
      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // 💰 MERCHANT EARNINGS
    match /merchantEarnings/{recordId} {
      allow read: if request.auth != null &&
        (resource.data.merchantId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);
      allow create, update: if request.auth == null ||
        (request.auth != null && userRole() in ["admin", "ceo", "superadmin"]);
      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ⭐ REVIEWS
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }
    
    // ==========================================
    // 🛒 SHOP CATEGORIES
    match /shopCategories/{categoryId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // 🎟️ VOUCHER REWARD CONFIGS
    match /voucherRewardConfigs/{configId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdminOrCEO();
    }

        // ==========================================
    // � OVERRIDE TRANSACTIONS
    match /overrideTransactions/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || userRole() in ["admin", "ceo", "superadmin"]);

      allow list: if request.auth != null &&
        request.query.where("userId", "==", request.auth.uid);

      allow create: if request.auth == null; // Allow server-side (Admin SDK) only

      allow update, delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }

    // ==========================================
    // �🔔 NOTIFICATIONS
    match /notifications/{notifId} {
      // Allow users to read their own notifications
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.recipientUid == request.auth.uid
      );
      // Allow users to create their own notifications
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Optionally, allow update/delete for marking as read or cleanup
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.recipientUid == request.auth.uid
      );
    }

    // ==========================================
    // 🔐 ACCOUNT RECOVERY REQUESTS
    match /accountRecoveryRequests/{requestId} {
      allow get: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        resource.data.uid == request.auth.uid
      );

      allow list: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        request.query.where("uid", "==", request.auth.uid)
      );

      // Created/updated by Admin SDK from Cloud Functions.
      allow create: if request.auth == null ||
        (
          request.auth != null &&
          (
            userRole() in ["admin", "ceo", "superadmin"] ||
            request.resource.data.uid == request.auth.uid
          )
        );

      allow update, delete: if request.auth == null ||
        (request.auth != null && userRole() in ["admin", "ceo", "superadmin"]);
    }

    // ==========================================
    // � DELIVERIES
    match /deliveries/{deliveryId} {
      allow read: if request.auth != null &&
        (
          resource.data.riderId == request.auth.uid ||
          resource.data.customerId == request.auth.uid ||
          resource.data.merchantId == request.auth.uid ||
          userRole() in ["admin", "ceo", "superadmin"]
        );

      allow list: if request.auth != null && (
        userRole() in ["admin", "ceo", "superadmin"] ||
        request.query.where("riderId", "==", request.auth.uid) ||
        request.query.where("customerId", "==", request.auth.uid) ||
        request.query.where("merchantId", "==", request.auth.uid)
      );

      allow create: if request.auth == null || (request.auth != null && userRole() in ["admin", "ceo", "superadmin"]);

      allow update: if request.auth != null &&
        (
          // Rider can update deliveries with location and status
          (resource.data.riderId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status", "lastUpdated", "notes", "lat", "lng", "currentLocation", "lastLocationUpdate"
            ])
          ) ||
          // Admin/CEO can update anything
          userRole() in ["admin", "ceo", "superadmin"]
        );

      allow delete: if request.auth != null && userRole() in ["admin", "ceo", "superadmin"];
    }
    // 👤 USER SHOP LOCATION (Delivery address tracking)
    match /usershoplocation/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    // ==========================================
    // �🚫 DENY EVERYTHING ELSE
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

