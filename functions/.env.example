# Firebase Cloud Functions email configuration for rider application confirmations
# Copy this file to functions/.env and replace the placeholder values before deploying.
# For Gmail, use a Google App Password instead of your normal account password.

SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM=Plezz Rider <your-email@gmail.com>
SMTP_PORT=465
SMTP_SECURE=true

# Optional for non-Gmail providers:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Public app URL included in the confirmation email
WEB_APP_URL=https://lutz1.github.io/damayan-savings
